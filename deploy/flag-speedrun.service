[Unit]
Description=Flag Speedrun
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/flag_speedrun
ExecStart=/usr/bin/env npm run start:backend
Restart=always
RestartSec=5
Environment=NODE_ENV=production
Environment=HOST=0.0.0.0
Environment=PORT=3001
Environment=CORS_ORIGIN=*

[Install]
WantedBy=multi-user.target
